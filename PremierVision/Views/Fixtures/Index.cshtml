@model FixtureListViewModel

@{
    ViewData["Title"] = "Fikstur";
}

<section class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="h3 mb-1">Fikstur</h1>
                <p class="text-muted mb-0">Bir sonraki asamada API-Football verileri burada kullanilacak.</p>
            </div>

            <form method="get" class="d-flex gap-2">
                <label class="form-label mb-0 align-self-center" for="week">Hafta</label>
                <select id="week" name="week" class="form-select" onchange="this.form.submit()">
                    @foreach (var week in Model.AvailableWeeks)
                    {
                        <option value="@week" selected="@(week == Model.CurrentWeek)">@week</option>
                    }
                </select>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Mac</th>
                        <th>Durum</th>
                        <th>Skor</th>
                        <th>Stadyum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Fixtures)
                    {
                        <tr>
                            <td>@item.KickoffUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-semibold">@item.HomeTeamName - @item.AwayTeamName</td>
                            <td>@item.Status</td>
                            <td>
                                @(item.HomeFullTimeScore.HasValue && item.AwayFullTimeScore.HasValue
                                    ? $"{item.HomeFullTimeScore} - {item.AwayFullTimeScore}"
                                    : "-")
                            </td>
                            <td>@item.VenueName</td>
                            <td>
                                <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-dark">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
