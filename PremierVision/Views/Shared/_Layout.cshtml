@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var hasBackdrop = !string.Equals(controller, "Admin", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PremierVision</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PremierVision.styles.css" asp-append-version="true" />
    <style>
        :root {
            --bg: #0d0a18;
            --bg2: #140f24;
            --card: #1a1630;
            --card2: #211b3b;
            --elevated: #2a2350;
            --green: #00e676;
            --blue: #2979ff;
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #f1ecff;
            --t2: #9d92c8;
            --t3: #63598d;
            --border: #31285b;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: "Barlow Condensed", sans-serif;
            --fb: "Barlow", sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            margin: 0;
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            position: relative;
            isolation: isolate;
            background-image:
                radial-gradient(ellipse at 15% 0%, rgba(108,92,231,.14) 0%, transparent 55%),
                radial-gradient(ellipse at 85% 0%, rgba(155,89,182,.1) 0%, transparent 50%);
        }
        body.with-backdrop::before {
            content: "";
            position: absolute;
            top: 86px;
            left: 0;
            right: 0;
            height: min(58vh, 680px);
            min-height: 460px;
            z-index: -1;
            pointer-events: none;
            background:
                linear-gradient(180deg, rgba(6,10,18,.08) 0%, rgba(6,10,18,.34) 42%, rgba(13,10,24,.92) 100%),
                url('/dosyalar/background.jpeg') center 18% / cover no-repeat;
            opacity: .92;
        }
        a { color: inherit; text-decoration: none; }
        img { display: block; }

        .nb {
            background: rgba(8,13,24,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5);
        }
        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0;
        }
        .brand-logo {
            width: 112px;
            height: 74px;
            object-fit: contain;
            object-position: center;
            display: block;
            filter: drop-shadow(0 4px 10px rgba(0,0,0,.25));
        }
        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px;
        }
        .brand-txt span { color: var(--green); }
        .nav-links { display: flex; }
        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr);
        }
        .nl::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 15px;
            right: 15px;
            height: 2px;
            background: var(--green);
            transform: scaleX(0);
            transition: var(--tr);
        }
        .nl:hover, .nl.active { color: var(--t1); }
        .nl:hover::after, .nl.active::after { transform: scaleX(1); }
        .nb-icons { display: flex; align-items: center; gap: 5px; }
        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr);
        }
        .ico-btn:hover {
            background: var(--elevated);
            color: var(--t1);
            border-color: var(--blue);
        }
        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1;
        }
        .mob-menu { max-height: 0; overflow: hidden; transition: max-height .3s ease; }
        .mob-menu.open { max-height: 320px; }
        .mob-menu .nl { padding: 14px 0; border-bottom: 1px solid var(--border); display: block; }
        .wrap { max-width: 1120px; margin: 0 auto; padding: 0 20px; }

        .lg-head {
            background: linear-gradient(135deg, rgba(20,15,36,.76), rgba(26,22,48,.54));
            border-bottom: 1px solid rgba(49,40,91,.22);
            padding: 32px 0 24px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(3px);
        }
        .lg-head::before {
            content: "";
            position: absolute;
            top: -40%;
            right: -5%;
            width: 380px;
            height: 380px;
            background: radial-gradient(circle, rgba(0,230,118,.05) 0%, transparent 70%);
            pointer-events: none;
        }
        .lg-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.22);
            border-radius: 20px;
            padding: 4px 12px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        .lg-title {
            font-family: var(--fd);
            font-size: clamp(26px, 5vw, 42px);
            font-weight: 900;
            letter-spacing: .5px;
            line-height: 1;
        }
        .lg-sub { font-size: 13px; color: var(--t2); margin-top: 6px; }
        .lg-stats {
            display: flex;
            gap: 24px;
            align-items: flex-end;
            justify-content: flex-end;
            height: 100%;
        }
        .ls-num {
            font-family: var(--fd);
            font-size: 30px;
            font-weight: 800;
            color: var(--green);
            line-height: 1;
        }
        .ls-lbl {
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 3px;
        }
        .ftabs-wrap {
            background: linear-gradient(135deg, rgba(20,15,36,.66), rgba(26,22,48,.44));
            border-top: 1px solid rgba(255,255,255,.03);
            border-bottom: 1px solid rgba(49,40,91,.18);
            position: sticky;
            top: 62px;
            z-index: 99;
            backdrop-filter: blur(12px);
        }
        .ftabs { display: flex; overflow-x: auto; scrollbar-width: none; }
        .ftabs::-webkit-scrollbar { display: none; }
        .ftab {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--t3);
            padding: 15px 18px;
            cursor: pointer;
            border: none;
            background: transparent;
            border-bottom: 2px solid transparent;
            transition: var(--tr);
            white-space: nowrap;
        }
        .ftab:hover { color: var(--t2); background: rgba(255,255,255,.02); }
        .ftab.active { color: var(--green); border-bottom-color: var(--green); }
        .live-dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            background: var(--live);
            border-radius: 50%;
            margin-right: 5px;
            animation: pdot 1.4s ease-in-out infinite;
        }
        @@keyframes pdot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: .4; transform: scale(.7); }
        }
        .bcnt {
            background: var(--live);
            color: #fff;
            border-radius: 9px;
            font-size: 10px;
            padding: 1px 6px;
            margin-left: 5px;
            font-weight: 700;
        }

        .feat-wrap { padding: 30px 0 6px; }
        .feat-lbl {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--green);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .feat-lbl::before {
            content: "";
            display: inline-block;
            width: 18px;
            height: 2px;
            background: var(--green);
        }
        .feat-card {
            background: linear-gradient(135deg, #0d1d38 0%, #13213e 50%, #0d1f30 100%);
            border: 1px solid rgba(41,121,255,.2);
            border-radius: var(--r3);
            padding: 30px 36px;
            position: relative;
            overflow: hidden;
            transition: var(--tr);
            display: block;
            color: inherit;
        }
        .feat-card:hover {
            border-color: rgba(41,121,255,.5);
            transform: translateY(-2px);
            box-shadow: 0 12px 44px rgba(0,0,0,.6);
            color: inherit;
        }
        .feat-card::after {
            content: "FEATURED MATCH";
            position: absolute;
            top: 14px;
            right: 18px;
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 2px;
            color: var(--gold);
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.2);
            padding: 3px 10px;
            border-radius: 10px;
        }
        .ft-team { display: flex; flex-direction: column; align-items: center; gap: 12px; }
        .ft-logo {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: var(--elevated);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 900;
            overflow: hidden;
        }
        .ft-logo img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }
        .ft-name { font-family: var(--fd); font-size: 18px; font-weight: 800; text-align: center; }
        .ft-type { font-size: 10px; color: var(--t3); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; }
        .ft-sc-area { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; }
        .ft-sc {
            font-family: var(--fd);
            font-size: clamp(48px, 8vw, 72px);
            font-weight: 900;
            letter-spacing: -3px;
            line-height: 1;
            background: linear-gradient(180deg, #fff 0%, #9ab5e0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .ft-stat, .ft-meta { text-align: center; }
        .ft-stat { font-family: var(--fd); font-size: 12px; font-weight: 700; letter-spacing: 1.5px; color: var(--t3); }
        .ft-meta { font-size: 12px; color: var(--t2); margin-top: 4px; }

        .sec-ttl {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t3);
            padding: 14px 0 8px;
            border-top: 1px solid var(--border);
            margin-top: 8px;
            margin-bottom: 4px;
        }
        .mc-wrap { margin-bottom: 8px; }
        .mc {
            width: 100%;
            display: flex;
            align-items: center;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 0 18px;
            min-height: 66px;
            overflow: hidden;
            transition: var(--tr);
            color: inherit;
        }
        .mc:hover {
            background: var(--card2);
            border-color: rgba(41,121,255,.3);
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(0,0,0,.4);
            color: inherit;
        }
        .mc.live {
            border-color: rgba(255,23,68,.22);
            background: linear-gradient(90deg, var(--card), rgba(255,23,68,.03));
        }
        .mc-time {
            flex-shrink: 0;
            width: 74px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 5px;
            padding: 12px 0;
        }
        .mc-min { font-family: var(--fd); font-size: 15px; font-weight: 700; color: var(--t2); }
        .mc-min.lc { color: var(--live); }
        .mc-min.bc { color: var(--blue); }
        .sbadge {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            padding: 2px 7px;
            border-radius: 9px;
            white-space: nowrap;
        }
        .sb-fin { background: rgba(143,163,200,.09); color: var(--t3); }
        .sb-live {
            background: rgba(255,23,68,.11);
            color: var(--live);
            border: 1px solid rgba(255,23,68,.2);
            display: flex;
            align-items: center;
            gap: 3px;
        }
        .sb-up { background: rgba(41,121,255,.1); color: var(--blue); }
        .dvv { width: 1px; height: 44px; background: var(--border); flex-shrink: 0; margin: 0 16px; }
        .mc-teams { flex: 1; min-width: 0; display: flex; flex-direction: column; }
        .mc-tr { display: flex; align-items: center; gap: 10px; padding: 5px 0; }
        .mc-tr:first-child { border-bottom: 1px solid rgba(255,255,255,.04); }
        .tl-sm {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--elevated);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            color: var(--t2);
            flex-shrink: 0;
            overflow: hidden;
        }
        .tl-sm img { width: 100%; height: 100%; object-fit: contain; padding: 3px; }
        .tn {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 700;
            letter-spacing: .2px;
            flex: 1;
            min-width: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .ts {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900;
            color: var(--t1);
            min-width: 26px;
            text-align: right;
            flex-shrink: 0;
        }
        .ts.win { color: var(--green); }
        .ts.dim { font-size: 15px; color: var(--t3); }
        .det-btn {
            flex-shrink: 0;
            margin-left: 16px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(41,121,255,.08);
            border: 1px solid rgba(41,121,255,.2);
            color: var(--blue);
            border-radius: var(--r1);
            padding: 6px 13px;
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: var(--tr);
            white-space: nowrap;
        }
        .det-btn:hover { background: rgba(41,121,255,.18); color: var(--blue); }

        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 36px;
        }
        .ft-brand { font-family: var(--fd); font-size: 20px; font-weight: 800; margin-bottom: 8px; }
        .ft-brand span { color: var(--green); }
        .ft-desc { font-size: 12px; color: var(--t3); line-height: 1.7; max-width: 240px; }
        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px;
        }
        .ft-ul { list-style: none; padding: 0; margin: 0; }
        .ft-ul li { margin-bottom: 7px; }
        .ft-ul a { color: var(--t3); font-size: 12px; transition: var(--tr); }
        .ft-ul a:hover { color: var(--t1); }
        .si-row { display: flex; gap: 7px; margin-top: 14px; }
        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px;
        }
        .si:hover { background: var(--elevated); color: var(--green); border-color: var(--green); }
        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px;
        }

        @@media (max-width: 600px) {
            body.with-backdrop::before {
                top: 74px;
                height: 48vh;
                min-height: 320px;
                background-position: center 24%;
            }
            .brand-logo { width: 90px; height: 60px; }
            .tn { font-size: 13px; }
            .ts { font-size: 18px; }
            .mc-time { width: 60px; }
            .dvv { margin: 0 10px; }
            .det-btn { padding: 5px 8px; font-size: 9px; }
            .det-btn span { display: none; }
            .feat-card { padding: 20px 14px; }
            .ft-logo { width: 52px; height: 52px; }
            .ft-name { font-size: 14px; }
            .ft-sc { font-size: 44px; }
            .lg-stats { display: none; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(hasBackdrop ? "with-backdrop" : string.Empty)">
    <nav class="nb">
        <div class="nb-inner">
            <a asp-controller="Home" asp-action="Index" class="brand">
                <img src="~/dosyalar/premierlogo.png" alt="PremierVision logo" class="brand-logo" />
                <span class="brand-txt">Premier<span>Vision</span></span>
            </a>
            <div class="nav-links d-none d-lg-flex">
                <a asp-controller="Home" asp-action="Index" class="nl @(controller == "Home" ? "active" : string.Empty)">Ana Sayfa</a>
                <a asp-controller="Fixtures" asp-action="Index" class="nl @(controller == "Fixtures" ? "active" : string.Empty)">Fikstür</a>
                <a asp-controller="Standings" asp-action="Index" class="nl @(controller == "Standings" ? "active" : string.Empty)">Puan Durumu</a>
                <a asp-controller="Admin" asp-action="Index" class="nl @(controller == "Admin" ? "active" : string.Empty)">Admin</a>
            </div>
            <div class="nb-icons">
                <button class="tog d-lg-none" id="tog" type="button"><i class="bi bi-list"></i></button>
            </div>
        </div>
        <div class="mob-menu" id="mobMenu">
            <div class="wrap">
                <a asp-controller="Home" asp-action="Index" class="nl d-block @(controller == "Home" ? "active" : string.Empty)">Ana Sayfa</a>
                <a asp-controller="Fixtures" asp-action="Index" class="nl d-block @(controller == "Fixtures" ? "active" : string.Empty)">Fikstür</a>
                <a asp-controller="Standings" asp-action="Index" class="nl d-block @(controller == "Standings" ? "active" : string.Empty)">Puan Durumu</a>
                <a asp-controller="Admin" asp-action="Index" class="nl d-block @(controller == "Admin" ? "active" : string.Empty)">Admin</a>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="ft">
        <div class="wrap">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="ft-brand">Premier<span>Vision</span></div>
                    <p class="ft-desc">Premier League maçları, puan durumu ve detay sayfaları için proje teması.</p>
                    <div class="si-row">
                        <a href="#" class="si"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="si"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="si"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="si"><i class="bi bi-telegram"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Ligler</div>
                    <ul class="ft-ul">
                        <li><a href="#">Premier League</a></li>
                        <li><a href="#">La Liga</a></li>
                        <li><a href="#">Bundesliga</a></li>
                        <li><a href="#">Serie A</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Hızlı Erişim</div>
                    <ul class="ft-ul">
                        <li><a asp-controller="Home" asp-action="Index">Haftalık Sonuçlar</a></li>
                        <li><a asp-controller="Fixtures" asp-action="Index">Fikstür</a></li>
                        <li><a asp-controller="Standings" asp-action="Index">Puan Durumu</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Takımlar</div>
                    <ul class="ft-ul">
                        <li><a href="#">Arsenal</a></li>
                        <li><a href="#">Liverpool</a></li>
                        <li><a href="#">Manchester City</a></li>
                        <li><a href="#">Chelsea</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Destek</div>
                    <ul class="ft-ul">
                        <li><a href="#">Hakkımızda</a></li>
                        <li><a href="#">İletişim</a></li>
                        <li><a href="#">Gizlilik</a></li>
                        <li><a href="#">Kullanım Şartları</a></li>
                    </ul>
                </div>
            </div>
            <div class="ft-bot">
                <span>&copy; 2026 PremierVision. Tüm hakları saklıdır.</span>
                <span>Premier League verileri demo ve eğitim amaçlıdır.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const tog = document.getElementById("tog");
        const mob = document.getElementById("mobMenu");
        if (tog && mob) {
            tog.addEventListener("click", () => {
                mob.classList.toggle("open");
                tog.innerHTML = mob.classList.contains("open")
                    ? '<i class="bi bi-x-lg"></i>'
                    : '<i class="bi bi-list"></i>';
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
