@model HomePageViewModel

@{
    ViewData["Title"] = "Ana Sayfa";

    var selectedFixtures = Model.WeeklyFixtures
        .OrderBy(x => x.KickoffUtc)
        .ToList();
    var selectedLiveFixtures = selectedFixtures
        .Where(x => x.Status == FixtureStatus.Live)
        .ToList();
    var selectedFinishedFixtures = selectedFixtures
        .Where(x => x.Status == FixtureStatus.Completed)
        .OrderByDescending(x => x.KickoffUtc)
        .ToList();
    var selectedUpcomingFixtures = selectedFixtures
        .Where(x => x.Status == FixtureStatus.NotStarted)
        .ToList();
    var liveCount = selectedLiveFixtures.Count;
    var finishedCount = selectedFinishedFixtures.Count;
    var upcomingCount = selectedUpcomingFixtures.Count;
    var totalCount = liveCount + finishedCount + upcomingCount;
    var featured = selectedLiveFixtures
        .OrderByDescending(x => x.KickoffUtc)
        .FirstOrDefault()
        ?? selectedFinishedFixtures.FirstOrDefault()
        ?? selectedUpcomingFixtures.FirstOrDefault()
        ?? selectedFixtures.FirstOrDefault();
    var prevWeek = Model.CurrentWeek;
    var nextWeek = Model.CurrentWeek;
    var nearbyWeeks = Array.Empty<int>();
    var weekStatusText = totalCount == 0
        ? "Bu hafta için maç bulunmuyor"
        : liveCount > 0
            ? $"{liveCount} maç canlı"
            : upcomingCount == 0
                ? "Haftanın tüm maçları tamamlandı"
                : finishedCount > 0
                    ? $"{finishedCount} tamamlandı, {upcomingCount} yaklaşan maç"
                    : $"{upcomingCount} yaklaşan maç";

    static int GetLiveMinute(FixtureCardViewModel fixture)
    {
        if (fixture.CurrentMinute.HasValue)
        {
            return Math.Clamp(fixture.CurrentMinute.Value, 1, 90);
        }

        var elapsedMinutes = (int)Math.Floor((DateTime.UtcNow - fixture.KickoffUtc).TotalMinutes);
        return Math.Clamp(elapsedMinutes > 0 ? elapsedMinutes : 1, 1, 90);
    }
}

@section Styles {
    <style>
        .home-main {
            padding-top: 28px;
            padding-bottom: 56px;
            min-height: 820px;
        }

        .sec-ttl[data-section="live"] {
            color: rgba(0,230,118,.78);
        }

        .mc.live {
            border-color: rgba(0,230,118,.3);
            background: linear-gradient(90deg, var(--card), rgba(0,230,118,.05));
        }

        .mc.live .mc-min.lc {
            color: var(--green);
        }

        .mc.live .sbadge.sb-live {
            background: rgba(0,230,118,.12);
            color: var(--green);
            border-color: rgba(0,230,118,.25);
        }

        .mc.live .live-dot {
            background: var(--green);
        }

        .empty-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 18px;
            color: var(--t2);
        }

        .week-select-card {
            width: 220px;
            position: relative;
            height: 54px;
            min-height: 54px;
            padding: 0;
            background:
                linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.018)),
                rgba(9,13,25,.68);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: var(--r2);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 18px 38px rgba(0,0,0,.24);
            transition: var(--tr);
            display: flex;
            align-items: center;
        }

        .week-select-card::before {
            content: "\F1F6";
            position: absolute;
            left: 10px;
            top: 50%;
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transform: translateY(-50%);
            color: var(--green);
            background: rgba(0,230,118,.1);
            border: 1px solid rgba(0,230,118,.2);
            border-radius: var(--r1);
            font-family: "bootstrap-icons";
            font-size: 14px;
            z-index: 1;
            pointer-events: none;
        }

        .week-select-card::after {
            content: "\F282";
            position: absolute;
            right: 10px;
            top: 50%;
            width: 26px;
            height: 26px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transform: translateY(-50%);
            color: var(--t2);
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 7px;
            font-family: "bootstrap-icons";
            font-size: 11px;
            z-index: 1;
            pointer-events: none;
        }

        .week-select-card:focus-within {
            border-color: rgba(0,230,118,.48);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 0 0 3px rgba(0,230,118,.09), 0 18px 38px rgba(0,0,0,.24);
        }

        .week-select-icon {
            display: none;
        }

        .week-arrow,
        .week-pill,
        .week-select-caret {
            display: none;
        }

        .week-center {
            display: block;
            width: 100%;
            height: 54px;
        }

        .week-select-wrap {
            position: relative;
            width: 100%;
            height: 54px;
        }

        .week-select-wrap::before {
            content: "Hafta Seçimi";
            position: absolute;
            top: 6px;
            left: 52px;
            color: var(--t3);
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            pointer-events: none;
            z-index: 3;
        }

        .week-select {
            width: 100%;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
            appearance: none;
            -webkit-appearance: none;
            padding: 21px 40px 0 52px;
            border: 0;
            background: transparent;
            color: var(--t1);
            font-family: var(--fd);
            font-size: 15px;
            font-weight: 900;
            letter-spacing: .5px;
            text-transform: uppercase;
            cursor: pointer;
            outline: none;
            z-index: 2;
            line-height: 1;
        }

        .week-select option {
            background: var(--bg2);
            color: var(--t1);
            font-family: var(--fb);
            font-size: 14px;
        }

        .week-select-label {
            display: none;
        }

        .week-select-caret {
            display: none;
        }

        .week-state {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            margin-top: 12px;
            color: var(--t2);
            font-size: 13px;
        }

        .week-state i {
            color: var(--green);
        }

        @@media (max-width: 991px) {
            .week-select-card {
                margin-top: 10px;
                width: 100%;
                max-width: 320px;
            }
        }
    </style>
}

<section class="lg-head">
    <div class="wrap">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="lg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div>
                <h1 class="lg-title"><span style="color:var(--green)">@Model.CurrentWeek.</span> Hafta Heyecanı</h1>
                <p class="lg-sub">Canlı skorlar, son tamamlanan maçlar ve yaklaşan karşılaşmalar</p>
                <div class="week-state"><i class="bi bi-activity"></i><span>@weekStatusText</span></div>
            </div>
            <div class="col-lg-5 mt-3 mt-lg-0">
                <div class="d-flex flex-column align-items-lg-end gap-3">
                    <div class="lg-stats d-none d-lg-flex">
                        <div class="lg-stat"><div class="ls-num">@liveCount</div><div class="ls-lbl">Canlı</div></div>
                        <div class="lg-stat"><div class="ls-num">@finishedCount</div><div class="ls-lbl">Biten</div></div>
                        <div class="lg-stat"><div class="ls-num">@upcomingCount</div><div class="ls-lbl">Yaklaşan</div></div>
                    </div>
                    <div class="week-select-card" aria-label="Hafta seçimi">
                        <div class="week-center">
                            <div class="week-select-wrap">
                                <select class="week-select" aria-label="Hafta listesi" onchange="if (this.value) window.location.href = this.value;">
                                    @foreach (var week in Model.AvailableWeeks)
                                    {
                                        if (week == Model.CurrentWeek)
                                        {
                                            <option value="@Url.Action("Index", "Home", new { week })" selected>Hafta @week</option>
                                        }
                                        else
                                        {
                                            <option value="@Url.Action("Index", "Home", new { week })">Hafta @week</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="ftabs-wrap">
    <div class="wrap">
        <div class="ftabs">
            <button class="ftab active" type="button" data-filter="all">Tüm Maçlar <span class="bcnt">@totalCount</span></button>
            <button class="ftab" type="button" data-filter="live"><span class="live-dot"></span>Canlı <span class="bcnt">@liveCount</span></button>
            <button class="ftab" type="button" data-filter="finished">Tamamlananlar</button>
            <button class="ftab" type="button" data-filter="upcoming">Yaklaşanlar</button>
        </div>
    </div>
</div>

<main>
    <div class="wrap home-main">
        @if (featured is not null)
        {
            var homeInitials = featured.HomeTeamName[..Math.Min(3, featured.HomeTeamName.Length)].ToUpperInvariant();
            var awayInitials = featured.AwayTeamName[..Math.Min(3, featured.AwayTeamName.Length)].ToUpperInvariant();
            var featuredScore = featured.Status == FixtureStatus.NotStarted
                ? "VS"
                : $"{featured.HomeFullTimeScore ?? 0}-{featured.AwayFullTimeScore ?? 0}";
            var featuredStatus = featured.Status == FixtureStatus.Completed
                ? "Maç Bitti"
                : featured.Status == FixtureStatus.Live
                    ? $"Canlı • {GetLiveMinute(featured)}'"
                    : "Yaklaşan Maç";

            <div class="feat-wrap" id="featuredBlock">
                <div class="feat-lbl">Öne Çıkan Maç</div>
                <a asp-controller="Matches" asp-action="Detail" asp-route-id="@featured.Id" class="feat-card">
                    <div class="row align-items-center g-2">
                        <div class="col-5">
                            <div class="ft-team">
                                <div class="ft-logo">
                                    @if (!string.IsNullOrWhiteSpace(featured.HomeTeamLogoUrl))
                                    {
                                        <img src="@featured.HomeTeamLogoUrl" alt="@featured.HomeTeamName logo" />
                                    }
                                    else
                                    {
                                        <span>@homeInitials</span>
                                    }
                                </div>
                                <div class="ft-name">@featured.HomeTeamName</div>
                                <div class="ft-type">Ev Sahibi</div>
                            </div>
                        </div>
                        <div class="col-2 text-center">
                            <div class="ft-sc-area">
                                <div class="ft-sc">@featuredScore</div>
                                <div class="ft-stat">@featuredStatus</div>
                                <div class="ft-meta">@featured.KickoffUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        </div>
                        <div class="col-5">
                            <div class="ft-team">
                                <div class="ft-logo">
                                    @if (!string.IsNullOrWhiteSpace(featured.AwayTeamLogoUrl))
                                    {
                                        <img src="@featured.AwayTeamLogoUrl" alt="@featured.AwayTeamName logo" />
                                    }
                                    else
                                    {
                                        <span>@awayInitials</span>
                                    }
                                </div>
                                <div class="ft-name">@featured.AwayTeamName</div>
                                <div class="ft-type">Deplasman</div>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-3" style="font-size:12px;color:var(--t2)">
                        <i class="bi bi-geo-alt"></i> @featured.VenueName
                        &nbsp;·&nbsp;
                        <span style="color:var(--blue)">Detayları Gör</span>
                    </div>
                </a>
            </div>
        }

        <div class="sec-ttl home-section" data-section="live">Canlı Maçlar</div>
        @if (selectedLiveFixtures.Count == 0)
        {
            <div class="empty-card home-section" data-section="live">Canlı maç bulunmuyor.</div>
        }
        else
        {
            @foreach (var liveEntry in selectedLiveFixtures.Select((item, index) => new { item, index }))
            {
                var item = liveEntry.item;
                var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
                var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();
                var homeWon = (item.HomeFullTimeScore ?? 0) > (item.AwayFullTimeScore ?? 0);
                var awayWon = (item.AwayFullTimeScore ?? 0) > (item.HomeFullTimeScore ?? 0);
                var displayMinute = GetLiveMinute(item);

                <div class="mc-wrap home-section" data-section="live">
                    <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc live">
                        <div class="mc-time">
                            <div class="mc-min lc">@displayMinute'</div>
                            <div class="sbadge sb-live"><span class="live-dot"></span>CANLI</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                                {
                                    <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@homeInitials</div>
                                }
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts @(homeWon ? "win" : string.Empty)">@item.HomeFullTimeScore</span>
                            </div>
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                                {
                                    <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@awayInitials</div>
                                }
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts @(awayWon ? "win" : string.Empty)">@item.AwayFullTimeScore</span>
                            </div>
                        </div>
                        <span class="det-btn"><i class="bi bi-chevron-right"></i><span>Detay</span></span>
                    </a>
                </div>
            }
        }

        <div class="sec-ttl home-section" data-section="finished">Tamamlanan Maçlar</div>
        @if (selectedFinishedFixtures.Count == 0)
        {
            <div class="empty-card home-section" data-section="finished">Tamamlanmış maç bulunmuyor.</div>
        }
        else
        {
            @foreach (var item in selectedFinishedFixtures)
            {
                var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
                var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();
                var homeWon = (item.HomeFullTimeScore ?? 0) > (item.AwayFullTimeScore ?? 0);
                var awayWon = (item.AwayFullTimeScore ?? 0) > (item.HomeFullTimeScore ?? 0);

                <div class="mc-wrap home-section" data-section="finished">
                    <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc">
                        <div class="mc-time">
                            <div class="mc-min">@item.KickoffUtc.ToLocalTime().ToString("HH:mm")</div>
                            <div class="sbadge sb-fin">MS</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                                {
                                    <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@homeInitials</div>
                                }
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts @(homeWon ? "win" : string.Empty)">@item.HomeFullTimeScore</span>
                            </div>
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                                {
                                    <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@awayInitials</div>
                                }
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts @(awayWon ? "win" : string.Empty)">@item.AwayFullTimeScore</span>
                            </div>
                        </div>
                        <span class="det-btn"><i class="bi bi-chevron-right"></i><span>Detay</span></span>
                    </a>
                </div>
            }
        }

        <div class="sec-ttl home-section" data-section="upcoming">Yaklaşan Maçlar</div>
        @if (selectedUpcomingFixtures.Count == 0)
        {
            <div class="empty-card home-section" data-section="upcoming">Yaklaşan maç bulunmuyor.</div>
        }
        else
        {
            @foreach (var item in selectedUpcomingFixtures)
            {
                var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
                var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();

                <div class="mc-wrap home-section" data-section="upcoming">
                    <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc">
                        <div class="mc-time">
                            <div class="mc-min bc">@item.KickoffUtc.ToLocalTime().ToString("HH:mm")</div>
                            <div class="sbadge sb-up">@item.KickoffUtc.ToLocalTime().ToString("dd MMM")</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                                {
                                    <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@homeInitials</div>
                                }
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts dim">-</span>
                            </div>
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                                {
                                    <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@awayInitials</div>
                                }
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts dim">-</span>
                            </div>
                        </div>
                        <span class="det-btn"><i class="bi bi-chevron-right"></i><span>Detay</span></span>
                    </a>
                </div>
            }
        }
    </div>
</main>

@section Scripts {
    <script>
        const tabs = document.querySelectorAll("[data-filter]");
        const sections = document.querySelectorAll(".home-section");
        const featured = document.getElementById("featuredBlock");
        const weekSelectCard = document.querySelector(".week-select-card");
        const weekSelect = document.querySelector(".week-select");

        if (weekSelectCard && weekSelect) {
            weekSelectCard.addEventListener("click", event => {
                if (event.target === weekSelect) {
                    return;
                }

                weekSelect.focus();

                if (typeof weekSelect.showPicker === "function") {
                    weekSelect.showPicker();
                }
            });
        }

        tabs.forEach(tab => {
            tab.addEventListener("click", () => {
                tabs.forEach(item => item.classList.remove("active"));
                tab.classList.add("active");

                const filter = tab.dataset.filter;

                sections.forEach(section => {
                    section.style.display = filter === "all" || section.dataset.section === filter
                        ? ""
                        : "none";
                });

                if (featured) {
                    featured.style.display = filter === "all" ? "" : "none";
                }
            });
        });
    </script>
}
