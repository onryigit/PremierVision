@model HomePageViewModel

@{
    ViewData["Title"] = "Ana Sayfa";

    var liveCount = Model.LiveFixtures.Count;
    var finishedCount = Model.LatestResults.Count;
    var upcomingCount = Model.UpcomingFixtures.Count;
    var totalCount = liveCount + finishedCount + upcomingCount;
    var featured = Model.FeaturedMatch;

    static int GetLiveMinute(DateTime kickoffUtc)
    {
        var elapsedMinutes = (int)Math.Floor((DateTime.UtcNow - kickoffUtc).TotalMinutes);
        return Math.Clamp(elapsedMinutes > 0 ? elapsedMinutes : 1, 1, 90);
    }
}

@section Styles {
    <style>
        .home-main {
            padding-top: 28px;
            padding-bottom: 56px;
        }

        .sec-ttl[data-section="live"] {
            color: rgba(0,230,118,.78);
        }

        .mc.live {
            border-color: rgba(0,230,118,.3);
            background: linear-gradient(90deg, var(--card), rgba(0,230,118,.05));
        }

        .mc.live .mc-min.lc {
            color: var(--green);
        }

        .mc.live .sbadge.sb-live {
            background: rgba(0,230,118,.12);
            color: var(--green);
            border-color: rgba(0,230,118,.25);
        }

        .mc.live .live-dot {
            background: var(--green);
        }

        .empty-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 18px;
            color: var(--t2);
        }
    </style>
}

<section class="lg-head">
    <div class="wrap">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="lg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div>
                <h1 class="lg-title">Hafta <span style="color:var(--green)">@Model.CurrentWeek</span> Merkezi</h1>
                <p class="lg-sub">Canli skorlar, son tamamlanan maclar ve yaklasan karsilasmalar tek ekranda</p>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="lg-stats">
                    <div style="text-align:center"><div class="ls-num">@liveCount</div><div class="ls-lbl">Canli</div></div>
                    <div style="text-align:center"><div class="ls-num">@finishedCount</div><div class="ls-lbl">Biten</div></div>
                    <div style="text-align:center"><div class="ls-num">@upcomingCount</div><div class="ls-lbl">Yaklasan</div></div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="ftabs-wrap">
    <div class="wrap">
        <div class="ftabs">
            <button class="ftab active" type="button" data-filter="all">Tum Maclar <span class="bcnt">@totalCount</span></button>
            <button class="ftab" type="button" data-filter="live"><span class="live-dot"></span>Canli <span class="bcnt">@liveCount</span></button>
            <button class="ftab" type="button" data-filter="finished">Tamamlananlar</button>
            <button class="ftab" type="button" data-filter="upcoming">Yaklasanlar</button>
        </div>
    </div>
</div>

<main>
    <div class="wrap home-main">
        @if (featured is not null)
        {
            var homeInitials = featured.HomeTeamName[..Math.Min(3, featured.HomeTeamName.Length)].ToUpperInvariant();
            var awayInitials = featured.AwayTeamName[..Math.Min(3, featured.AwayTeamName.Length)].ToUpperInvariant();
            var featuredScore = featured.Status == FixtureStatus.NotStarted
                ? "VS"
                : $"{featured.HomeFullTimeScore ?? 0}-{featured.AwayFullTimeScore ?? 0}";
            var featuredStatus = featured.Status == FixtureStatus.Completed
                ? "Mac Bitti"
                : featured.Status == FixtureStatus.Live
                    ? $"Canli • {GetLiveMinute(featured.KickoffUtc)}'"
                    : "Yaklasan Mac";

            <div class="feat-wrap" id="featuredBlock">
                <div class="feat-lbl">One Cikan Mac</div>
                <a asp-controller="Matches" asp-action="Detail" asp-route-id="@featured.Id" class="feat-card">
                    <div class="row align-items-center g-2">
                        <div class="col-5">
                            <div class="ft-team">
                                <div class="ft-logo">
                                    @if (!string.IsNullOrWhiteSpace(featured.HomeTeamLogoUrl))
                                    {
                                        <img src="@featured.HomeTeamLogoUrl" alt="@featured.HomeTeamName logo" />
                                    }
                                    else
                                    {
                                        <span>@homeInitials</span>
                                    }
                                </div>
                                <div class="ft-name">@featured.HomeTeamName</div>
                                <div class="ft-type">Ev Sahibi</div>
                            </div>
                        </div>
                        <div class="col-2 text-center">
                            <div class="ft-sc-area">
                                <div class="ft-sc">@featuredScore</div>
                                <div class="ft-stat">@featuredStatus</div>
                                <div class="ft-meta">@featured.KickoffUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        </div>
                        <div class="col-5">
                            <div class="ft-team">
                                <div class="ft-logo">
                                    @if (!string.IsNullOrWhiteSpace(featured.AwayTeamLogoUrl))
                                    {
                                        <img src="@featured.AwayTeamLogoUrl" alt="@featured.AwayTeamName logo" />
                                    }
                                    else
                                    {
                                        <span>@awayInitials</span>
                                    }
                                </div>
                                <div class="ft-name">@featured.AwayTeamName</div>
                                <div class="ft-type">Deplasman</div>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-3" style="font-size:12px;color:var(--t2)">
                        <i class="bi bi-geo-alt"></i> @featured.VenueName
                        &nbsp;·&nbsp;
                        <span style="color:var(--blue)">Detaylari Gor</span>
                    </div>
                </a>
            </div>
        }

        <div class="sec-ttl home-section" data-section="live">Canli Maclar</div>
        @if (Model.LiveFixtures.Count == 0)
        {
            <div class="empty-card home-section" data-section="live">Canli mac bulunmuyor.</div>
        }
        else
        {
            @foreach (var item in Model.LiveFixtures)
            {
                var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
                var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();
                var homeWon = (item.HomeFullTimeScore ?? 0) > (item.AwayFullTimeScore ?? 0);
                var awayWon = (item.AwayFullTimeScore ?? 0) > (item.HomeFullTimeScore ?? 0);
                var liveMinute = GetLiveMinute(item.KickoffUtc);

                <div class="mc-wrap home-section" data-section="live">
                    <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc live">
                        <div class="mc-time">
                            <div class="mc-min lc">@liveMinute'</div>
                            <div class="sbadge sb-live"><span class="live-dot"></span>CANLI</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                                {
                                    <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@homeInitials</div>
                                }
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts @(homeWon ? "win" : string.Empty)">@item.HomeFullTimeScore</span>
                            </div>
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                                {
                                    <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@awayInitials</div>
                                }
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts @(awayWon ? "win" : string.Empty)">@item.AwayFullTimeScore</span>
                            </div>
                        </div>
                        <span class="det-btn"><i class="bi bi-chevron-right"></i><span>Detay</span></span>
                    </a>
                </div>
            }
        }

        <div class="sec-ttl home-section" data-section="finished">Tamamlanan Maclar</div>
        @if (Model.LatestResults.Count == 0)
        {
            <div class="empty-card home-section" data-section="finished">Tamamlanmis mac bulunmuyor.</div>
        }
        else
        {
            @foreach (var item in Model.LatestResults)
            {
                var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
                var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();
                var homeWon = (item.HomeFullTimeScore ?? 0) > (item.AwayFullTimeScore ?? 0);
                var awayWon = (item.AwayFullTimeScore ?? 0) > (item.HomeFullTimeScore ?? 0);

                <div class="mc-wrap home-section" data-section="finished">
                    <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc">
                        <div class="mc-time">
                            <div class="mc-min">@item.KickoffUtc.ToLocalTime().ToString("HH:mm")</div>
                            <div class="sbadge sb-fin">MS</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                                {
                                    <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@homeInitials</div>
                                }
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts @(homeWon ? "win" : string.Empty)">@item.HomeFullTimeScore</span>
                            </div>
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                                {
                                    <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@awayInitials</div>
                                }
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts @(awayWon ? "win" : string.Empty)">@item.AwayFullTimeScore</span>
                            </div>
                        </div>
                        <span class="det-btn"><i class="bi bi-chevron-right"></i><span>Detay</span></span>
                    </a>
                </div>
            }
        }

        <div class="sec-ttl home-section" data-section="upcoming">Yaklasan Maclar</div>
        @if (Model.UpcomingFixtures.Count == 0)
        {
            <div class="empty-card home-section" data-section="upcoming">Yaklasan mac bulunmuyor.</div>
        }
        else
        {
            @foreach (var item in Model.UpcomingFixtures)
            {
                var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
                var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();

                <div class="mc-wrap home-section" data-section="upcoming">
                    <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc">
                        <div class="mc-time">
                            <div class="mc-min bc">@item.KickoffUtc.ToLocalTime().ToString("HH:mm")</div>
                            <div class="sbadge sb-up">@item.KickoffUtc.ToLocalTime().ToString("dd MMM")</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                                {
                                    <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@homeInitials</div>
                                }
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts dim">-</span>
                            </div>
                            <div class="mc-tr">
                                @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                                {
                                    <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="background:#fff;padding:3px" />
                                }
                                else
                                {
                                    <div class="tl-sm">@awayInitials</div>
                                }
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts dim">-</span>
                            </div>
                        </div>
                        <span class="det-btn"><i class="bi bi-chevron-right"></i><span>Detay</span></span>
                    </a>
                </div>
            }
        }
    </div>
</main>

@section Scripts {
    <script>
        const tabs = document.querySelectorAll("[data-filter]");
        const sections = document.querySelectorAll(".home-section");
        const featured = document.getElementById("featuredBlock");

        tabs.forEach(tab => {
            tab.addEventListener("click", () => {
                tabs.forEach(item => item.classList.remove("active"));
                tab.classList.add("active");

                const filter = tab.dataset.filter;

                sections.forEach(section => {
                    section.style.display = filter === "all" || section.dataset.section === filter
                        ? ""
                        : "none";
                });

                if (featured) {
                    featured.style.display = filter === "all" ? "" : "none";
                }
            });
        });
    </script>
}
