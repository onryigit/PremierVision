@model HomePageViewModel

@{
    ViewData["Title"] = "Ana Sayfa";
    var totalMatches = Model.WeeklyFixtures.Count;
    var completedMatches = Model.WeeklyFixtures.Count(x => x.Status == FixtureStatus.Completed);
    var liveMatches = Model.WeeklyFixtures.Count(x => x.Status == FixtureStatus.Live);
    var upcomingMatches = Model.WeeklyFixtures.Count(x => x.Status == FixtureStatus.NotStarted);
}

<section class="lg-head">
    <div class="wrap">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="lg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div>
                <h1 class="lg-title">Hafta <span style="color:var(--green)">@Model.CurrentWeek</span> Sonuclari</h1>
                <p class="lg-sub">Case gereksinimine uygun olarak secilen haftanin tum maclari ve skor bilgileri</p>
            </div>
            <div class="col-lg-5">
                <form method="get" class="d-flex align-items-center justify-content-lg-end gap-2 py-2">
                    <label for="week" class="small text-uppercase" style="letter-spacing:1px;color:var(--t2)">Hafta</label>
                    <select id="week" name="week" class="form-select form-select-sm" style="max-width:180px" onchange="this.form.submit()">
                        @foreach (var week in Model.AvailableWeeks)
                        {
                            <option value="@week" selected="@(week == Model.CurrentWeek)">@week. hafta</option>
                        }
                    </select>
                </form>
            </div>
        </div>
    </div>
</section>

<main>
    <div class="wrap" style="padding-top:28px;padding-bottom:56px">
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body text-center">
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--blue)">@totalMatches</div>
                        <div class="small text-uppercase" style="letter-spacing:1px;color:var(--t3)">Toplam Mac</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body text-center">
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--green)">@completedMatches</div>
                        <div class="small text-uppercase" style="letter-spacing:1px;color:var(--t3)">Tamamlandi</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body text-center">
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--live)">@liveMatches</div>
                        <div class="small text-uppercase" style="letter-spacing:1px;color:var(--t3)">Devam Ediyor</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body text-center">
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--gold)">@upcomingMatches</div>
                        <div class="small text-uppercase" style="letter-spacing:1px;color:var(--t3)">Henuz Oynanmadi</div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.WeeklyFixtures.Count == 0)
        {
            <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                <div class="card-body">
                    Secilen hafta icin mac bulunamadi.
                </div>
            </div>
        }

        @foreach (var item in Model.WeeklyFixtures)
        {
            var homeInitials = item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpperInvariant();
            var awayInitials = item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpperInvariant();

            <div class="mc-wrap">
                <a asp-controller="Matches" asp-action="Detail" asp-route-id="@item.Id" class="mc @(item.Status == FixtureStatus.Live ? "live" : string.Empty)">
                    <div class="mc-time">
                        <div class="mc-min @(item.Status == FixtureStatus.Live ? "lc" : item.Status == FixtureStatus.NotStarted ? "bc" : string.Empty)">
                            @(item.Status == FixtureStatus.Live ? "CANLI" : item.KickoffUtc.ToLocalTime().ToString("HH:mm"))
                        </div>
                        <div class="sbadge @(item.Status == FixtureStatus.Completed ? "sb-fin" : item.Status == FixtureStatus.Live ? "sb-live" : "sb-up")">
                            @if (item.Status == FixtureStatus.Live)
                            {
                                <span class="live-dot"></span>
                            }
                            @(item.Status == FixtureStatus.Completed ? "MS" : item.Status == FixtureStatus.Live ? "CANLI" : item.KickoffUtc.ToLocalTime().ToString("dd MMM"))
                        </div>
                    </div>
                    <div class="dvv"></div>
                    <div class="mc-teams">
                        <div class="mc-tr">
                            @if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl))
                            {
                                <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName logo" class="tl-sm" style="object-fit:contain;background:#fff;padding:3px" />
                            }
                            else
                            {
                                <div class="tl-sm">@homeInitials</div>
                            }
                            <span class="tn">@item.HomeTeamName</span>
                            <span class="ts @(item.Status == FixtureStatus.NotStarted ? "dim" : string.Empty)">
                                @(item.Status == FixtureStatus.NotStarted ? "-" : (item.HomeFullTimeScore ?? 0).ToString())
                            </span>
                        </div>
                        <div class="mc-tr">
                            @if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl))
                            {
                                <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName logo" class="tl-sm" style="object-fit:contain;background:#fff;padding:3px" />
                            }
                            else
                            {
                                <div class="tl-sm">@awayInitials</div>
                            }
                            <span class="tn">@item.AwayTeamName</span>
                            <span class="ts @(item.Status == FixtureStatus.NotStarted ? "dim" : string.Empty)">
                                @(item.Status == FixtureStatus.NotStarted ? "-" : (item.AwayFullTimeScore ?? 0).ToString())
                            </span>
                        </div>
                    </div>
                    <div class="text-end small" style="min-width:150px;color:var(--t3)">
                        <div>@item.VenueName</div>
                        <div>Hafta @item.MatchWeek</div>
                    </div>
                    <span class="det-btn ms-3"><i class="bi bi-chevron-right"></i> <span>Detay</span></span>
                </a>
            </div>
        }
    </div>
</main>
