@model StandingsPageViewModel

@{
    ViewData["Title"] = "Puan Durumu";
    var leader = Model.Rows.FirstOrDefault();
    var topScoring = Model.Rows.OrderByDescending(x => x.GoalsFor).FirstOrDefault();
    var bestDefense = Model.Rows.OrderBy(x => x.GoalsAgainst).FirstOrDefault();
}

<section class="pg-head">
    <div class="wrap">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="pg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div>
                <h1 class="pg-title">Puan <span style="color:var(--green)">Durumu</span></h1>
                <p class="pg-sub">Mac sonuclarindan dinamik hesaplanan lig tablosu</p>
            </div>
            <div class="col-lg-4 mt-3 mt-lg-0">
                <div class="d-flex flex-wrap gap-2 justify-content-lg-end small">
                    <span class="px-2 py-1 rounded" style="background:rgba(255,214,0,.09);border:1px solid rgba(255,214,0,.22);color:var(--gold)">Sampiyon</span>
                    <span class="px-2 py-1 rounded" style="background:rgba(0,230,118,.09);border:1px solid rgba(0,230,118,.22);color:var(--green)">Avrupa</span>
                    <span class="px-2 py-1 rounded" style="background:rgba(255,23,68,.09);border:1px solid rgba(255,23,68,.22);color:var(--live)">Kume Dusme</span>
                </div>
            </div>
        </div>
    </div>
</section>

<main>
    <div class="wrap" style="padding-top:28px;padding-bottom:56px">
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body">
                        <div class="small text-uppercase mb-2" style="letter-spacing:1px;color:var(--t3)">Lider</div>
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--gold)">@(leader?.TeamName ?? "-")</div>
                        <div class="small" style="color:var(--t2)">@(leader?.Points ?? 0) puan</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body">
                        <div class="small text-uppercase mb-2" style="letter-spacing:1px;color:var(--t3)">En Cok Gol</div>
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--green)">@(topScoring?.GoalsFor ?? 0)</div>
                        <div class="small" style="color:var(--t2)">@(topScoring?.TeamName ?? "-")</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="card border-0 shadow-sm" style="background:var(--card);border:1px solid var(--border)!important;color:var(--t1)">
                    <div class="card-body">
                        <div class="small text-uppercase mb-2" style="letter-spacing:1px;color:var(--t3)">En Az Yenen</div>
                        <div class="h2 mb-1" style="font-family:var(--fd);font-weight:900;color:var(--blue)">@(bestDefense?.GoalsAgainst ?? 0)</div>
                        <div class="small" style="color:var(--t2)">@(bestDefense?.TeamName ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive rounded-4 shadow-sm" style="border:1px solid var(--border);background:var(--card)">
            <table class="table align-middle mb-0">
                <thead>
                    <tr style="color:var(--t3)">
                        <th>#</th>
                        <th>Takim</th>
                        <th>O</th>
                        <th>G</th>
                        <th>B</th>
                        <th>M</th>
                        <th>AG</th>
                        <th>YG</th>
                        <th>AV</th>
                        <th>Form</th>
                        <th>P</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Rows)
                    {
                        var rowColor = item.Position == 1
                            ? "rgba(255,214,0,.55)"
                            : item.Position <= 4
                                ? "rgba(0,230,118,.7)"
                                : item.Position >= Math.Max(Model.Rows.Count - 2, 1)
                                    ? "rgba(255,23,68,.7)"
                                    : "transparent";
                        <tr style="color:var(--t1)">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span style="display:inline-block;width:4px;height:36px;border-radius:2px;background:@rowColor"></span>
                                    <strong>@item.Position</strong>
                                </div>
                            </td>
                            <td class="fw-semibold">@item.TeamName</td>
                            <td>@item.Played</td>
                            <td style="color:var(--green)">@item.Wins</td>
                            <td style="color:var(--t2)">@item.Draws</td>
                            <td style="color:var(--live)">@item.Losses</td>
                            <td>@item.GoalsFor</td>
                            <td>@item.GoalsAgainst</td>
                            <td style="color:@(item.GoalDifference > 0 ? "var(--green)" : item.GoalDifference < 0 ? "var(--live)" : "var(--t2)")">@item.GoalDifference</td>
                            <td>@item.Form</td>
                            <td class="fw-bold fs-5">@item.Points</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>
